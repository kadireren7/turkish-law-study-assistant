    "coverage:audit": "tsx scripts/coverage-audit.ts"
  },
  "dependencies": {
    "docx": "^9.5.0",
    "next": "^16.1.6",
    "rss-parser": "^3.13.0",
    "openai": "^4.52.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "playwright": "^1.49.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.9.0"
  }
